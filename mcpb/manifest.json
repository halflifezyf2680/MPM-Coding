{
  "manifest_version": "0.3",
  "name": "mpm-coding",
  "display_name": "MPM-Coding",
  "version": "0.0.0",
  "description": "Local MCP server for engineering workflows: AST-based code navigation, impact/flow analysis, task orchestration, and memo/recall memory.",
  "author": {
    "name": "halflifezyf2680"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/halflifezyf2680/MPM-Coding"
  },
  "server": {
    "type": "binary",
    "entry_point": "server/linux/mpm-go",
    "mcp_config": {
      "command": "server/linux/mpm-go",
      "args": [],
      "env": {},
      "platform_overrides": {
        "darwin": {
          "command": "server/darwin/mpm-go",
          "args": []
        },
        "win32": {
          "command": "server/win32/mpm-go.exe",
          "args": []
        }
      }
    }
  },
  "compatibility": {
    "platforms": ["linux", "darwin", "win32"]
  }
}
