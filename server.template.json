{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "${MCP_SERVER_NAME}",
  "title": "MPM",
  "description": "Local MCP server for engineering workflows: AST-based code navigation, impact/flow analysis, task orchestration, and memo/recall memory.",
  "version": "${VERSION}",
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "${MCPB_DOWNLOAD_URL}",
      "fileSha256": "${MCPB_SHA256}",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "repository": {
    "url": "${GITHUB_REPO_URL}",
    "source": "github"
  },
  "websiteUrl": "${GITHUB_REPO_URL}"
}
